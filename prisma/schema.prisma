generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  RECEPTIONIST
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum ReminderChannel {
  WHATSAPP
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

enum BlockedTimeScope {
  SALON
  PROFESSIONAL
}

model Salon {
  id                     String                     @id @default(cuid())
  name                   String
  slug                   String                     @unique
  legalName              String?
  phone                  String
  whatsappNumber         String?
  email                  String?
  description            String?
  timezone               String                     @default("America/Sao_Paulo")
  addressLine1           String?
  addressLine2           String?
  city                   String?
  state                  String?
  postalCode             String?
  country                String                     @default("BR")
  bookingGraceMinutes    Int                        @default(0)
  bookingLeadMinutes     Int                        @default(60)
  cancellationLeadHours  Int                        @default(6)
  slotIntervalMinutes    Int                        @default(15)
  planCode               String                     @default("starter")
  billingStatus          String                     @default("trialing")
  trialStartsAt          DateTime?
  trialEndsAt            DateTime?
  subscriptionEndsAt     DateTime?
  billingProvider        String?
  billingCustomerId      String?
  billingSubscriptionId  String?
  billingDocumentId      String?
  billingMethod          String?
  isActive               Boolean                    @default(true)
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  users                  User[]
  professionals          Professional[]
  services               Service[]
  customers              Customer[]
  appointments           Appointment[]
  businessHours          SalonBusinessHour[]
  blockedTimes           BlockedTime[]
  googleConnections      GoogleCalendarConnection[]
  notificationLogs       NotificationLog[]
}

model User {
  id           String    @id @default(cuid())
  salonId      String
  name         String
  email        String
  passwordHash String
  role         UserRole  @default(OWNER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  salon        Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, email])
  @@index([salonId, role])
}

model Professional {
  id                String                @id @default(cuid())
  salonId           String
  name              String
  slug              String
  phone             String?
  email             String?
  bio               String?
  specialty         String?
  avatarUrl         String?
  colorHex          String?
  googleCalendarId  String?
  bufferBeforeMin   Int                   @default(0)
  bufferAfterMin    Int                   @default(0)
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  salon             Salon                 @relation(fields: [salonId], references: [id], onDelete: Cascade)
  serviceLinks      ProfessionalService[]
  schedules         ProfessionalSchedule[]
  blockedTimes      BlockedTime[]
  appointments      Appointment[]

  @@unique([salonId, slug])
  @@index([salonId, isActive])
}

model Service {
  id                  String                @id @default(cuid())
  salonId             String
  name                String
  slug                String
  category            String?
  description         String?
  durationMin         Int
  priceCents          Int
  cleanupBufferMin    Int                   @default(0)
  isActive            Boolean               @default(true)
  onlineBooking       Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  salon               Salon                 @relation(fields: [salonId], references: [id], onDelete: Cascade)
  professionalLinks   ProfessionalService[]
  appointments        Appointment[]

  @@unique([salonId, slug])
  @@index([salonId, isActive])
}

model ProfessionalService {
  professionalId String
  serviceId      String
  customPriceCents Int?
  customDurationMin Int?
  createdAt      DateTime     @default(now())
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
}

model Customer {
  id                 String         @id @default(cuid())
  salonId            String
  fullName           String
  phone              String
  email              String?
  notes              String?
  whatsappOptInAt    DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  salon              Salon          @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointments       Appointment[]

  @@unique([salonId, phone])
  @@index([salonId, fullName])
}

model Appointment {
  id                    String              @id @default(cuid())
  salonId               String
  customerId            String
  professionalId        String
  serviceId             String
  status                AppointmentStatus   @default(CONFIRMED)
  source                String              @default("public_booking")
  startAt               DateTime
  endAt                 DateTime
  customerNameSnapshot  String
  customerPhoneSnapshot String
  serviceNameSnapshot   String
  servicePriceCents     Int
  durationMinSnapshot   Int
  internalNotes         String?
  cancellationReason    String?
  canceledAt            DateTime?
  completedAt           DateTime?
  googleCalendarEventId String?
  googleSyncStatus      String              @default("not_configured")
  googleSyncError       String?
  googleSyncedAt        DateTime?
  googleTargetCalendarId String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  salon                 Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer              Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  professional          Professional        @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  service               Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  notificationLogs      NotificationLog[]

  @@index([salonId, startAt, status])
  @@index([professionalId, startAt, status])
  @@index([customerId, startAt])
}

model SalonBusinessHour {
  id        String   @id @default(cuid())
  salonId   String
  weekday   Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId, weekday])
}

model ProfessionalSchedule {
  id             String   @id @default(cuid())
  professionalId String
  weekday        Int
  startTime      String
  endTime        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  breaks         ScheduleBreak[]

  @@index([professionalId, weekday])
}

model ScheduleBreak {
  id                   String   @id @default(cuid())
  professionalScheduleId String
  startTime            String
  endTime              String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  professionalSchedule ProfessionalSchedule @relation(fields: [professionalScheduleId], references: [id], onDelete: Cascade)

  @@index([professionalScheduleId])
}

model BlockedTime {
  id             String           @id @default(cuid())
  salonId        String
  professionalId String?
  scope          BlockedTimeScope
  title          String
  reason         String?
  startAt        DateTime
  endAt          DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  salon          Salon            @relation(fields: [salonId], references: [id], onDelete: Cascade)
  professional   Professional?    @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([salonId, startAt, endAt])
  @@index([professionalId, startAt, endAt])
}

model GoogleCalendarConnection {
  id                    String   @id @default(cuid())
  salonId               String
  professionalId        String?
  googleAccountEmail    String
  calendarId            String
  refreshTokenEncrypted String
  accessTokenEncrypted  String?
  tokenExpiresAt        DateTime?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  salon                 Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId, isActive])
}

model NotificationLog {
  id              String             @id @default(cuid())
  salonId         String
  appointmentId   String
  channel         ReminderChannel
  templateKey     String
  recipient       String
  scheduledFor    DateTime?
  sentAt          DateTime?
  status          NotificationStatus @default(PENDING)
  provider        String?
  providerMessageId String?
  errorMessage    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  salon           Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointment     Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([salonId, status, scheduledFor])
  @@index([appointmentId, channel])
}
